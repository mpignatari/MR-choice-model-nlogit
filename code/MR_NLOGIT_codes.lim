/* Latent Class Model (Fixed parameters, ACMA) Hensher pg.726 


Timer$
calc;ran(1)$
sample;all$
?reject; Str_clsc=1$
?reject; protest=6$
reject; exclall3=1$
skip
create; p1,p2$
namelist; pc=p1,p2$ ?Nlogit Ref Guide, pg. 461
lclogit;lhs=y ?lcrplogit results suggest that coeffs are not random.
;choices=one,two,neither
?;rhs=mr,job,carbon,cost
?;shuffle 
?;halton
?;maxit=40 ?; tlg=0.000001  
?;rpl
?;show
?;mlhs
?;fcn=MR(n),Job(n),Carbon(n),Cost(t) ? wierd result when cost is distributed lognormal (even when minus sign is included and when Halton draws are used).?triangular with just t is different than t,1.
;pts= 2 ? # of classes (note that specification in Nlogit ref guide page N-459 does not work here.
;pds=4
;wts=wtgend
;lcm ?= inc2s,inc3s,inc4s ?educ2s,educ3s,educ4s,age2s,age3s
?;par (together with matrix?) store conditional parameter estimates (Hensher et al., pages 646-647)
?;wtp=mr/cost,job/cost,carbon/cost
?;matrix
;model:
u(one)= opt1 + MR*MR + Job*Job + Carbon*Carbon + Cost*Cost/
u(two)= MR*MR + Job*Job + Carbon*Carbon + Cost*Cost/
u(neither)= 0;output=ic
;par;wtp=mr/cost;classp=pc
;rst=
?ACMA:
b1aopt1,b2amr,b2amr,b4acarbon,b5acost,
b1bopt1,b2bmr,b3bjob,b3bjob,b5bcost$

/* ex post stated ANA - ML-EC model*/
create; if(CE_eval2=6|CE_eval2=7)ana=1$
create; anamr=ana*mr$
create; anajob=ana*job$
create; anacarb=ana*carbon$
create; anacost=ana*cost$ 
calc;ran(1)$
sample;all$
reject; exclall3=1$
skip
nlogit;lhs=y;wts=wtgend;pds=4;rpl;
choices=one,two,neither;
model:
u(one)=mr*mr+anamr*anamr+job*job+anajob*anajob+carbon*carbon+anacarb*anacarb+cost*cost+anacost*anacost/
u(two)=mr*mr+anamr*anamr+job*job+anajob*anajob+carbon*carbon+anacarb*anacarb+cost*cost+anacost*anacost/
u(neither)=b0;
output=ic;fcn=b0(n),mr(n),job(n),carbon(n),cost(t);ecm=(one,two);halton;pts=1000;parameter$

