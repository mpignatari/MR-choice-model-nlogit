?RPL-EC WTP-Space
nlrplogit;lhs=yadj;
    choices=one,two,neither; maxit=200;
    labels=b,w1,w2,w3,a;start=-100,3.5,1,3,-0.003;
    Fn1=u1=a*(-w1*MR-w2*Job-w3*Carbon+Cost);
    Fn2=u2=a*(-w1*MR-w2*Job-w3*Carbon+Cost);
    Fn3=u3=a*(-b);
    Model:
    U(one)=u1/
    U(two)=u2/
    U(neither)=u3;
    fcn=b(n),w1(n),w2(n),w3(n),a(t,1);halton;pts=1000;pds=4;parameters;ECM=(one,two);Output=IC$
?GMXL
GMXLOGIT;lhs=yadj;
    choices=one,two,neither;
    Par;halton;pts=1000;pds=4;Output=IC;wts=wtgend; Tau=0.5;
    ; Fcn = b0(n),MR(n),Job(n),Carbon(n), Cost(*o);
    model:
    U(one)=MR*MR + Job*Job + Carbon*Carbon + Cost*cost/
    U(two)=MR*MR + Job*Job + Carbon*Carbon + Cost*cost/
    U(neither)=b0$

??RPL Linear Model Results with Fisherman's Interactions by Subsamples Related to General Recreation (Table N)
?General Recreation
nlogit;lhs=y;wts=wtgend;
    choices=one,two,neither;pds=4;rpl
    ;model:
    u(one)= b0 + MR*MR + Job*Job + Carbon*Carbon + Cost*Cost + b0fish*b0fish + mrfish*mrfish + jobfish*jobfish +carbfish*carbfish /
    u(two)= b0 + MR*MR + Job*Job + Carbon*Carbon + Cost*Cost + b0fish*b0fish + mrfish*mrfish + jobfish*jobfish +carbfish*carbfish /
    u(neither)= MR*MR + Job*Job + Carbon*Carbon + Cost*Cost + b0fish*b0fish + mrfish*mrfish + jobfish*jobfish +carbfish*carbfish;
output=ic;fcn=b0(n),MR(n),Job(n),Carbon(n),Cost(n);halton;pts=1000;parameters; WTP=-b0/Cost,-MR/Cost,-Job/Cost,-Carbon/Cost$
?No-general Recreation
nlogit;lhs=y;wts=wtgend;
    choices=one,two,neither;pds=4;rpl
    ;model:
    u(one)= b0 + MR*MR + Job*Job + Carbon*Carbon + Cost*Cost + b0fish*b0fish + mrfish*mrfish + jobfish*jobfish +carbfish*carbfish /
    u(two)= b0 + MR*MR + Job*Job + Carbon*Carbon + Cost*Cost + b0fish*b0fish + mrfish*mrfish + jobfish*jobfish +carbfish*carbfish /
    u(neither)= MR*MR + Job*Job + Carbon*Carbon + Cost*Cost + b0fish*b0fish + mrfish*mrfish + jobfish*jobfish +carbfish*carbfish;
    output=ic;fcn=b0(n),MR(n),Job(n),Carbon(n),Cost(n);halton;pts=1000;parameters; WTP=-b0/Cost,-MR/Cost,-Job/Cost,-Carbon/Cost$

