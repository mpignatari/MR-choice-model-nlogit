    u(two)= b0 + MR*MR + Job*Job + Carbon*Carbon + Cost*Cost + mrjob*mrjob + mrcarb*mrcarb + mrcost*mrcost +jobcarb*jobcarb + jobcost*jobcost +carbcost*carbcost+erc1/
    u(neither)= MR*MR + Job*Job + Carbon*Carbon + Cost*Cost + mrjob*mrjob + mrcarb*mrcarb + mrcost*mrcost +jobcarb*jobcarb + jobcost*jobcost +carbcost*carbcost;
    output=ic;fcn=b0(n),MR(n),Job(n),Carbon(n),Cost(o);halton;pts=1000;parameters$
?RPL-EC
nlogit;lhs=y;wts=wtgend;
    choices=one,two,neither;pds=4;rpl
    ;model:
    u(one)= b0 + MR*MR + Job*Job + Carbon*Carbon + Cost*Cost + mrjob*mrjob + mrcarb*mrcarb + mrcost*mrcost +jobcarb*jobcarb + jobcost*jobcost +carbcost*carbcost+erc1/
    u(two)= b0 + MR*MR + Job*Job + Carbon*Carbon + Cost*Cost + mrjob*mrjob + mrcarb*mrcarb + mrcost*mrcost +jobcarb*jobcarb + jobcost*jobcost +carbcost*carbcost+erc1/
    u(neither)= MR*MR + Job*Job + Carbon*Carbon + Cost*Cost + mrjob*mrjob + mrcarb*mrcarb + mrcost*mrcost +jobcarb*jobcarb + jobcost*jobcost +carbcost*carbcost;
    output=ic;fcn=b0(n),MR(n),Job(n),Carbon(n),Cost(o),erc1(n,*,0);halton;pts=1000;parameters$

