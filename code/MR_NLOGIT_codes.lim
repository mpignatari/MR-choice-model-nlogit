/*Latent Class Model (Standard Model with 3 classes, Fixed parameters) */

create; if(CE_cert>50)certain1=1$
create; if(Age=3|Age=4)age2s=1$
create; if(Age=5|Age=6)age3s=1$
create; if(Educ=3|Educ=4)educ2s=1$
create; if(Educ=5)educ3s=1$
create; if(Educ=6)educ4s=1$
create; if(Inc=3|Inc=4)inc2s=1$
create; if(Inc=5|Inc=6)inc3s=1$
create; if(Inc=7)inc4s=1$
create; if(Latino=1)latino1=1$
create; if(Gender=1)gender1=1$
create; if(Gender=2)gender2=1$
create; if(Emp=1)emp1=1$
create; if(Emp=2)emp2=1$
create; if(Emp=3)emp3=1$
create; if(Emp=4)emp4=1$
create; if(Emp=5)emp5=1$
create; if(Emp=6)emp6=1$
create; if(Reside=4 | Reside=5)urban=1$
create; if(Bias=2)bias2=1$


calc;ran(1)$
sample;all$
?reject; Str_clsc=1$
?reject; protest=6$
reject; exclall3=1$
skip
create; p1,p2,p3$
namelist; pc=p1,p2,p3$ ?Nlogit Ref Guide, pg. 461
lclogit;lhs=y ?lcrplogit results suggest that coeffs are not random.
;choices=one,two,neither
?;rhs=mr,job,carbon,cost
?;shuffle 
?;halton
?;maxit=40 ?; tlg=0.000001  
?;rpl
?;show
?;mlhs
?;fcn=MR(n),Job(n),Carbon(n),Cost(t) ? wierd result when cost is distributed lognormal (even when minus sign is included and when Halton draws are used).?triangular with just t is different than t,1.
;pts= 3 ? # of classes (note that specification in Nlogit ref guide page N-459 does not work here.
;pds=4
;wts=wtgend
;lcm ? = inc2s,inc3s,inc4s,educ2s,educ3s,educ4s,age2s,age3s
?;par (together with matrix?) store conditional parameter estimates (Hensher et al., pages 646-647)
?;matrix
;model:
u(one)= b01 + MR*MR + Job*Job + Carbon*Carbon + Cost*Cost/
u(two)= b01 + MR*MR + Job*Job + Carbon*Carbon + Cost*Cost/
u(neither)= 0;output=ic
;par;classp=pc ?Nlogit Ref Guide page N-462
;rst=
?restricts ASC to be same across all classes:
b1ab01,b2amr,b3ajob,b4acarbon,b5acost,
b1ab01,b2bmr,b3bjob,b4bcarbon,b5bcost,
b1ab01,b2cmr,b3cjob,b4ccarbon,b5ccost$


