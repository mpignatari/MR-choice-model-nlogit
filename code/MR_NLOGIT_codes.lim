    choices=one,two,neither;
    model:
    u(one)= MR*MR + Job*Job + Carbon*Carbon + Cost*cost/
    u(two)= MR*MR + Job*Job + Carbon*Carbon + Cost*cost/
    u(neither)= b0;
    output=ic;fcn=b0(n),MR(n),Job(n),Carbon(n),Cost(t);ECM=(one,two);WTP=-MR/Cost,-Job/Cost,-Carbon/Cost;halton;pts=1000;parameters;corr$
wald ;
