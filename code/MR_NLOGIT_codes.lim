reset$
???Marine Research - Final

?Load and filter the data
import; file=C:\Users\A02369659\Documents\12-2020\Marine Project\New Data\MR_dataset.csv$
create;nopt=3$
sample;all$
reject; exclall3=1$
skip$
dstat;rhs=*$

??Linear Model Results (Tables 3 and 4)
?RPL
nlogit;lhs=y;wts=wtgend;pds=4;rpl;
    choices=one,two,neither;
    model:
    u(one)= MR*MR + Job*Job + Carbon*Carbon + Cost*cost/
    u(two)= MR*MR + Job*Job + Carbon*Carbon + Cost*cost/
    u(neither)= b0;
    output=ic;fcn=b0(n),MR(n),Job(n),Carbon(n),Cost(t);WTP=-MR/Cost,-Job/Cost,-Carbon/Cost;halton;pts=1000;parameters;corr$
wald ;
    ; fn1 = wtp_b01 = -b1/b5
    ; fn2 = wtp_mr = -b2/b5
    ; fn3 = wtp_job = -b3/b5
    ; fn4 = wtp_carb = -b4/b5
    ; Pts = 2000$
?Scenarios WTP (Table 8)
wald ;
    ; fn1 = wtp_sc1 = (-(b2*50)-(b3*200)-(b4*100))/b5
    ; fn2 = wtp_sc2 = (-(b2*25)-(b3*100)-(b4*50))/b5
    ; fn3 = wtp_sc3 = (-b1)/b5
    ; fn4 = wtp_sc4 = (-(b2*(-50))-(b3*(-200))-(b4*0))/b5
    ; Pts = 2000$

?RPL-EC
