??Non-Linear Model Results (Tables 5 and 6)
create; if(mr=-50)mr1=1$
create; if(mr=50)mr3=1$
create; if(job=-200)job1=1$
create; if(job=200)job3=1$
create; if(carbon=25)carb2=1$
create; if(carbon=50)carb3=1$
create; if(carbon=100)carb4=1$
?RPL
nlogit;lhs=y;wts=wtgend;pds=4;rpl;
    choices=one,two,neither;
    model:
    U(one)=b0 + mr1*mr1+ mr3*mr3 + job1*job1+ job3*job3 + carb2*carb2 + carb3*carb3 + carb4*carb4 + Cost*Cost/
    U(two)=b0 + mr1*mr1+ mr3*mr3 + job1*job1+ job3*job3 + carb2*carb2 + carb3*carb3 + carb4*carb4 + Cost*Cost/
    U(neither)=mr1*mr1+ mr3*mr3 + job1*job1+ job3*job3 + carb2*carb2 + carb3*carb3 + carb4*carb4 + Cost*Cost;
    output=ic; Fcn =b0(n), mr1(n),mr3(n),job1(n), job3(n), carb2(n) ,carb3(n),carb4(n), Cost(t);halton;pts=1000;parameters;corr$
wald ;
    ; fn1 = wtp_b01 = -b1/b9
    ; fn2 = wtp_mr1 = -b2/b9
    ; fn3 = wtp_mr3 = -b3/b9
    ; fn4 = wtp_job1 = -b4/b9
    ; fn5 = wtp_job3 = -b5/b9
    ; fn6 = wtp_carb2 = -b6/b9
    ; fn7 = wtp_carb3 = -b6/b9
    ; fn8 = wtp_carb4 = -b6/b9
    ; Pts = 2000$
?RPL-EC
nlogit;lhs=y;wts=wtgend;pds=4;rpl;
    choices=one,two,neither;
    model:
    U(one)=b0 + mr1*mr1+ mr3*mr3 + job1*job1+ job3*job3 + carb2*carb2 + carb3*carb3 + carb4*carb4 + Cost*Cost/
    U(two)=b0 + mr1*mr1+ mr3*mr3 + job1*job1+ job3*job3 + carb2*carb2 + carb3*carb3 + carb4*carb4 + Cost*Cost/
    U(neither)=mr1*mr1+ mr3*mr3 + job1*job1+ job3*job3 + carb2*carb2 + carb3*carb3 + carb4*carb4 + Cost*Cost;
    output=ic; Fcn =b0(n), mr1(n),mr3(n),job1(n), job3(n), carb2(n) ,carb3(n),carb4(n), Cost(t);ECM=(one,two);halton;pts=1000;parameters;corr$
?wald ;
    ; fn1 = wtp_b01 = -b1/b9
    ; fn2 = wtp_mr1 = -b2/b9
    ; fn3 = wtp_mr3 = -b3/b9
    ; fn4 = wtp_job1 = -b4/b9
    ; fn5 = wtp_job3 = -b5/b9
    ; fn6 = wtp_c2 = -b6/b9
    ; fn7 = wtp_c3 = -b7/b9
    ; fn8 = wtp_c4 = -b8/b9
    ; Pts = 2000$
?RPL-EC WTP-Space
nlrplogit;lhs=y;
    choices=one,two,neither;
    labels=b,w1,w2,w3,w4,w5,w6,w7,a;start=-100,-164,146,-136,116,25,50,100,-0.006;
    Fn1=u1=a*(-w1*mr1-w2*mr3-w3*job1-w4*job3-w5*carb2-w6*carb3-w7*carb4+Cost);
    Fn2=u2=a*(-w1*mr1-w2*mr3-w3*job1-w4*job3-w5*carb2-w6*carb3-w7*carb4+Cost);
    Fn3=u3=a*(-b);
    Model:
    U(one)=u1/
    U(two)=u2/
    U(neither)=u3;
    fcn=b(n),w1(n),w2(n),w3(n),w4(n),w5(n),w6(n),w7(n),a(t,1);halton;pts=1000;pds=4;parameters;ECM=(one,two);Output=IC$

