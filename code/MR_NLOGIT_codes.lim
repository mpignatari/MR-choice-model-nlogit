?Scenarios WTP (Table 8)
wald ;
    ; fn1 = wtp_sc1 = (-(b2*50)-(b3*200)-(b4*100))/b5
    ; fn2 = wtp_sc2 = (-(b2*25)-(b3*100)-(b4*50))/b5
    ; fn3 = wtp_sc3 = (-b1)/b5
    ; fn4 = wtp_sc4 = (-(b2*(-50))-(b3*(-200))-(b4*0))/b5
    ; Pts = 2000$

?RPL-EC WTP-Space
nlrplogit;lhs=y;	
    choices=one,two,neither;	
    labels=b,w1,w2,w3,a;start=-60,3.5,1,3,-0.003;	
    Fn1=u1=a*(-w1*MR-w2*Job-w3*Carbon+Cost);	
    Fn2=u2=a*(-w1*MR-w2*Job-w3*Carbon+Cost);	
    Fn3=u3=a*(-b);	
    Model:	
    U(one)=u1/	
    U(two)=u2/	
    U(neither)=u3;	
    fcn=b(n),w1(n),w2(n),w3(n),a(t,1);halton;pts=1000;pds=4;parameters;Output=IC;ECM=(one,two);Parameters$
?Scenarios WTP (Tables 8)
wald ;
